// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       String @id @default(uuid()) @db.Uuid // serve para gerar um id único para cada usuário
  name     String
  email    String @unique
  password String

  @@map("users") // mapeia a tabela do banco de dados para o nome "users", alterando o nome da tabela padrão que seria "User"
}
